{
  "name": "whatsmo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "android:env": "ANDROID_HOME=$PWD/.local/android-sdk ANDROID_SDK_ROOT=$PWD/.local/android-sdk ANDROID_NDK_HOME=$PWD/.local/android-sdk/ndk/27.0.12077973 NDK_HOME=$PWD/.local/android-sdk/ndk/27.0.12077973 CARGO_HOME=$PWD/.local/cargo GRADLE_USER_HOME=$PWD/.local/gradle TMPDIR=$PWD/.local/tmp PATH=$PWD/.local/android-sdk/platform-tools:$PWD/.local/android-sdk/cmdline-tools/latest/bin:$PATH",
    "android:setup": "scripts/setup-android-sdk.sh",
    "android:init": "bun run android:env tauri android init",
    "android:dev": "bun run android:env tauri android dev",
    "android:build": "bun run android:env tauri android build",
    "android:build:apk": "bun run android:env tauri android build --apk --target aarch64 --ci",
    "android:build:apk:debug": "bun run android:env tauri android build --debug --apk --target aarch64 --ci",
    "android:build:apk:test": "scripts/build-release-test-apk.sh",
    "android:run": "bun run android:env tauri android run",
    "android:install": "scripts/install-apk.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "material-symbols": "0.44.4",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.10.0",
    "@types/bun": "^1.3.4",
    "@types/qrcode": "^1.5.6",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
